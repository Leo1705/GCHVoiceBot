# ElevenLabs — required for the assistant’s voice (TTS). Get a key at https://elevenlabs.io
# Without this, the app falls back to browser text-to-speech.
ELEVENLABS_API_KEY=

# Optional: for ElevenLabs Conversational AI / agent mode (not used in current flow).
# ELEVENLABS_AGENT_ID=

# Do not set ELEVENLABS_VOICE_ID_* — app uses free-tier premade voices only (see src/lib/constants.js).

# Voice therapist AI in legacy mode. Required for real therapist-style responses; without it, fallback is keyword-only.
OPENAI_API_KEY=sk-...

# Optional: extra instructions for the voice therapist (e.g. tone, approach, topics to emphasize).
# THERAPIST_EXTRA_PROMPT=

# Admin-only: secret for /api/ingest and /admin/knowledge (teach the assistant). Not visible to users.
ADMIN_SECRET=

# Email to therapist after session (optional). If not set, session is still saved to data/sessions.json but no email is sent.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=voice-therapy@yourdomain.com
