# ElevenLabs — required for the assistant’s voice (TTS). Get a key at https://elevenlabs.io
# Without this, the app falls back to browser text-to-speech.
ELEVENLABS_API_KEY=

# Optional: for ElevenLabs Conversational AI / agent mode (not used in current flow).
# ELEVENLABS_AGENT_ID=

# Voice IDs are set in src/lib/constants.js (VOICE_PROFILES). No env override.

# Voice therapist AI in legacy mode. Required for real therapist-style responses; without it, fallback is keyword-only.
OPENAI_API_KEY=sk-...

# Optional: extra instructions for the voice therapist (e.g. tone, approach, topics to emphasize).
# THERAPIST_EXTRA_PROMPT=

# Admin-only: secret for /api/ingest and /admin/knowledge (teach the assistant). Not visible to users.
ADMIN_SECRET=

# --- Email to therapist after session (pick ONE method) ---
# Session is always saved to data/sessions.json; email needs one of the below.
#
# Option A — Resend (free tier: https://resend.com — sign up, create API key, no credit card for basic use)
# 1. Create account → API Keys → create key starting with re_
# 2. Domains → add greaterchangehealth.com (or your domain) and verify DNS so you can send to any address
# 3. Use a "From" like: sessions@yourdomain.com (must be on verified domain)
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=sessions@yourdomain.com
#
# Option B — Classic SMTP (Gmail app password, SendGrid, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=voice-therapy@yourdomain.com
